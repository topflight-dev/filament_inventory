# C3DW Next.js Monorepo — Environment Variable Template
# Copy this file to `.env.local` (gitignored) and fill in real values.
# NEVER commit `.env.local` — it is already excluded via .gitignore.

# ─────────────────────────────────────────────────────────────────────────────
# PUBLIC (build-time, exposed to the browser) — safe because RLS protects data
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://oyusccplccayyltmfdup.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Default multi-tenant shop slug used by /request when no `?shop=` URL
# param is present. This is a slug identifier only (not a secret), safe to
# expose to the browser. Must match a real row in the `shops` table's
# `shop_slug` column. See web/src/app/(marketing)/request/page.tsx for the
# full 3-tier fallback chain (URL param > this env var > hardcoded default).
NEXT_PUBLIC_DEFAULT_SHOP_SLUG=crafted3dworkshop


# ─────────────────────────────────────────────────────────────────────────────
# SERVER-ONLY (never exposed to the browser, never prefixed with NEXT_PUBLIC_)
# Used exclusively inside Route Handlers (src/app/api/*/route.ts).
# Replaces the legacy /api/env.js endpoint, which publicly leaked these values
# in plaintext — see Project_Log.md Phase 1 "Flagged Findings" #1.
# ─────────────────────────────────────────────────────────────────────────────
ADMIN_KEY=
DISCORD_WEBHOOK_URL=
