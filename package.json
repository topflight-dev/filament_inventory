{
  "name": "filament_inventory_site",
  "version": "1.0.0",
  "type": "module",
  "description": "Crafted 3D Printing – Filament Inventory Site\r A web-based inventory and gallery for managing 3D printing filament and showcasing printed projects. Built with HTML, CSS, and modular JavaScript, with Airtable integration for live inventory data.",
  "main": "main.cjs",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "serve": "node server.js",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.crafted3d.workshophub",
    "productName": "C3DW Hub",
    "win": {
      "target": "portable",
      "icon": "icon.png"
    },
    "files": [
      "main.cjs",
      "package.json",
      "src/pages/admin/**/*",
      "styles/**/*",
      "js/**/*",
      "icon.png"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blast1221/filament_inventory.git"
  },
  "engines": {
    "node": "20.x"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@cline/sdk": "^0.0.41",
    "@supabase/supabase-js": "^2.89.0",
    "airtable": "^0.12.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "helmet": "^8.1.0"
  },
  "bugs": {
    "url": "https://github.com/blast1221/filament_inventory/issues"
  },
  "homepage": "https://github.com/blast1221/filament_inventory#readme",
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1"
  }
}
